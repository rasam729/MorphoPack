# Copy to `.env` and fill values for local development

# Postgres (Supabase/Neon) connection URL
# Example: postgresql://db_user:password@db.host:5432/dbname
DATABASE_URL=

# Azure Blob Storage connection string (optional)
AZURE_STORAGE_CONNECTION_STRING=

# API base used by the frontend build (no trailing slash)
VITE_API_BASE=http://localhost:7071/api

# Engine (Blender) service base (if running MorphoPackEngine separately)
ENGINE_BASE=http://localhost:5050/api
